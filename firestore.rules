rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Único admin habilitado hoy (no hay sistema de roles todavía).
    // Para sumar otro admin, agregar su UID a esta lista.
    function isAdmin() {
      return request.auth != null && request.auth.uid in ['vJVgS8PZpSOro7OmcRLtOxMowXy1'];
    }

    match /tiendas/{tiendaId} {
      allow read: if true;
      // Solo el admin puede escribir, y solo puede tocar el campo "activa"
      // (activar/desactivar tienda desde el panel), no el resto del documento.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activa']);
      allow create, delete: if false;

      match /productos/{productoId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /conductores/{conductorId} {
      // Un conductor puede leer su propio documento (para ver su switch
      // "Disponible" al recargar la app); el admin puede leer cualquiera.
      allow get: if isAdmin() || request.auth.uid == conductorId;
      // Listar todos los conductores queda limitado al panel de admin.
      allow list: if isAdmin();
      allow update: if
        // El admin solo puede tocar "cuotaSemanalPagada".
        (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cuotaSemanalPagada']))
        // El propio conductor solo puede tocar su disponibilidad, ubicación
        // y su token de push (fcmToken): lo necesita escribir él mismo cada
        // vez que se pone disponible o se loguea, ya que ese token identifica
        // SU dispositivo y solo él puede generarlo/renovarlo (nunca su cuota,
        // ni la de otro conductor).
        || (request.auth.uid == conductorId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activo', 'ubicacion', 'fcmToken']));
      allow create, delete: if false;
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Mismo esquema que pedidos: el cliente crea el viaje sin iniciar sesión,
    // cualquiera puede leer un viaje puntual para seguirlo, y solo usuarios
    // autenticados (conductores/admin) pueden listar o actualizar estado.
    match /viajes/{viajeId} {
      allow create: if true;
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
