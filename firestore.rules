rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Único admin habilitado hoy (no hay sistema de roles todavía).
    // PUENTE SUPABASE -> FIREBASE (ver api/firebase-token.js): con el login
    // unificado en Supabase, `request.auth.uid` acá deja de ser el uid de
    // Firebase Auth del admin y pasa a ser su uid de SUPABASE (el custom
    // token de Firebase se minta con uid = uid de Supabase). El admin
    // TODAVÍA NO TIENE cuenta de Supabase, así que el uid de abajo es un
    // PLACEHOLDER: hay que reemplazarlo por el uid real de Supabase del
    // admin (tabla `usuarios`, tipo_usuario = 'admin') una vez que esa
    // cuenta exista, y volver a publicar estas reglas
    // (firebase deploy --only firestore:rules) — hasta entonces el admin NO
    // va a poder pasar isAdmin().
    function isAdmin() {
      return request.auth != null && request.auth.uid in ['a8ac6be6-1f57-4f17-adb0-2e92d393f570'];
    }

    // El resto de las reglas de abajo (conductores, viajes, pedidos) NO
    // necesita cambios por el puente: siguen comparando contra
    // `request.auth.uid`/`request.auth != null` tal cual, y eso sigue
    // siendo válido porque el custom token de Firebase que emite el puente
    // trae uid = uid de Supabase — mismo id con el que ya se crean los docs
    // de `conductores/{uid}` (ver api/admin-aprobar-conductor.js) y con el
    // que el conductor va a tener sesión de Firebase activa.

    match /tiendas/{tiendaId} {
      allow read: if true;
      // Solo el admin puede escribir, y solo puede tocar el campo "activa"
      // (activar/desactivar tienda desde el panel), no el resto del documento.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activa']);
      allow create, delete: if false;

      match /productos/{productoId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /conductores/{conductorId} {
      // Un conductor puede leer su propio documento (para ver su switch
      // "Disponible" al recargar la app); el admin puede leer cualquiera.
      allow get: if isAdmin() || request.auth.uid == conductorId;
      // Listar todos los conductores queda limitado al panel de admin.
      allow list: if isAdmin();
      allow update: if
        // El admin solo puede tocar "cuotaSemanalPagada".
        (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cuotaSemanalPagada']))
        // El propio conductor solo puede tocar su disponibilidad, ubicación
        // y su token de push (fcmToken): lo necesita escribir él mismo cada
        // vez que se pone disponible o se loguea, ya que ese token identifica
        // SU dispositivo y solo él puede generarlo/renovarlo (nunca su cuota,
        // ni la de otro conductor).
        || (request.auth.uid == conductorId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activo', 'ubicacion', 'fcmToken']));
      allow create, delete: if false;
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Mismo esquema que pedidos: el cliente crea el viaje sin iniciar sesión,
    // cualquiera puede leer un viaje puntual para seguirlo, y solo usuarios
    // autenticados (conductores/admin) pueden listar o actualizar estado.
    match /viajes/{viajeId} {
      allow create: if true;
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Configuración global de la app (hoy: tarifas para cotizar el precio de
    // un viaje). El cliente no tiene login y necesita leer esto en el
    // navegador ANTES de crear el viaje (para mostrar el precio estimado),
    // por eso es de lectura pública. No se edita desde el cliente ni desde
    // ninguna función: los valores se cargan/ajustan a mano desde la consola
    // de Firebase, igual que "nombre"/"telefono" en conductores/{uid}.
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
